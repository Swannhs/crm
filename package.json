    "compose:down": "./manage.sh dev down",
    "compose:ps": "./manage.sh dev ps"
  },
  "devDependencies": {
    "prisma": "^6.19.3",
    "tsx": "^4.19.0"
  },
  "dependencies": {
    "@prisma/client": "6.19.3"
  }
}
