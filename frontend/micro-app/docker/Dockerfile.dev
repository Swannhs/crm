FROM node:24-alpine

WORKDIR /app

ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3034

COPY package.json ./

RUN corepack enable

EXPOSE 3034

CMD ["sh", "-c", "set -e; cd /app; mkdir -p node_modules; INSTALL_STAMP=/app/node_modules/.install-complete; INSTALL_HASH_FILE=/app/node_modules/.install-hash; if [ -f yarn.lock ]; then DESIRED_HASH=$(sha256sum package.json yarn.lock | sha256sum | awk '{print $1}'); else DESIRED_HASH=$(sha256sum package.json | awk '{print $1}'); fi; CURRENT_HASH=''; if [ -f \"$INSTALL_HASH_FILE\" ]; then CURRENT_HASH=$(cat \"$INSTALL_HASH_FILE\"); fi; if [ ! -f \"$INSTALL_STAMP\" ] || [ \"$CURRENT_HASH\" != \"$DESIRED_HASH\" ]; then echo 'Installing frontend dependencies...'; corepack yarn install --frozen-lockfile --network-timeout 600000; printf '%s' \"$DESIRED_HASH\" > \"$INSTALL_HASH_FILE\"; date -u +'%Y-%m-%dT%H:%M:%SZ' > \"$INSTALL_STAMP\"; else echo 'Frontend dependencies are up to date.'; fi; exec corepack yarn dev"]
