generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model EmailAccount {
  id              String   @id @default(uuid())
  orgId           String
  userId          String
  email           String   @unique
  provider        String   // gmail, outlook
  isConnected     Boolean  @default(true)
  lastSyncAt      DateTime?
  syncStatus      String   @default("idle") // idle, syncing, error
  errorMessage    String?
  settings        Json?    // Sync preferences
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  emails          Email[]
  threads         EmailThread[]
  syncLogs        SyncLog[]

  @@index([orgId])
  @@index([userId])
  @@index([orgId, userId])
  @@map("email_accounts")
}

model Email {
  id            String   @id @default(uuid())
  orgId         String
  accountId     String
  threadId      String?
  messageId     String   @unique // Provider's message ID
  subject       String?
  fromName      String?
  fromEmail     String
  toEmails      String[] 
  ccEmails      String[]
  bccEmails     String[]
  replyToEmails String[]
  textBody      String?
  htmlBody      String?
  snippet       String?
  hasAttachments Boolean @default(false)
  attachmentCount Int   @default(0)
  labels        String[] // Gmail labels or Outlook categories
  isRead        Boolean  @default(false)
  isStarred     Boolean  @default(false)
  isImportant   Boolean  @default(false)
  direction     String   // inbound, outbound
  sentAt        DateTime
  receivedAt    DateTime @default(now())
  rawHeaders    Json?
  inReplyTo     String?
  references    String[]
  relatedDealId String?
  relatedContactId String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  account       EmailAccount @relation(fields: [accountId], references: [id])
  thread        EmailThread? @relation(fields: [threadId], references: [id])

  @@index([orgId])
  @@index([accountId])
  @@index([threadId])
  @@index([fromEmail])
  @@index([relatedDealId])
  @@index([relatedContactId])
  @@index([orgId, fromEmail])
  @@index([orgId, sentAt])
  @@map("emails")
}

model EmailThread {
  id            String   @id @default(uuid())
  orgId         String
  accountId     String
  subject       String?
  firstMessageId String  @unique
  lastMessageId String?
  messageCount  Int      @default(1)
  participants  String[] // All email addresses in thread
  lastMessageAt DateTime
  relatedDealId String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  emails        Email[]
  account       EmailAccount @relation(fields: [accountId], references: [id])

  @@index([orgId])
  @@index([accountId])
  @@index([relatedDealId])
  @@index([orgId, lastMessageAt])
  @@map("email_threads")
}

model SyncLog {
  id            String   @id @default(uuid())
  orgId         String
  accountId     String
  status        String   // success, partial, error
  emailsSynced  Int      @default(0)
  threadsSynced Int      @default(0)
  errors        String[]
  startedAt     DateTime @default(now())
  completedAt   DateTime?
  duration      Int?     // milliseconds
  
  account       EmailAccount @relation(fields: [accountId], references: [id])

  @@index([orgId])
  @@index([accountId])
  @@index([orgId, startedAt])
  @@map("sync_logs")
}

model EmailTemplate {
  id            String   @id @default(uuid())
  orgId         String
  name          String
  subject       String
  body          String   // HTML or plain text
  category      String?  // sales, support, marketing
  variables     String[] // Template variables like {{firstName}}, {{company}}
  isPublic      Boolean  @default(false)
  usageCount    Int      @default(0)
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([orgId])
  @@index([createdBy])
  @@index([orgId, category])
  @@map("email_templates")
}

model EmailSequence {
  id            String   @id @default(uuid())
  orgId         String
  name          String
  description   String?
  isActive      Boolean  @default(true)
  steps         Json     // Array of sequence steps with delay and template
  totalDuration Int      // Total duration in days
  enrollmentCount Int    @default(0)
  completionRate Float   @default(0)
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  enrollments   SequenceEnrollment[]

  @@index([orgId])
  @@index([createdBy])
  @@map("email_sequences")
}

model SequenceEnrollment {
  id            String   @id @default(uuid())
  orgId         String
  sequenceId    String
  contactEmail  String
  contactId     String?
  dealId        String?
  status        String   @default("active") // active, paused, completed, unsubscribed
  currentStep   Int      @default(0)
  startedAt     DateTime @default(now())
  completedAt   DateTime?
  unsubscribedAt DateTime?
  
  sequence      EmailSequence @relation(fields: [sequenceId], references: [id])
  activities    SequenceActivity[]

  @@index([orgId])
  @@index([sequenceId])
  @@index([contactEmail])
  @@index([contactId])
  @@index([dealId])
  @@index([orgId, status])
  @@map("sequence_enrollments")
}

model SequenceActivity {
  id            String   @id @default(uuid())
  orgId         String
  enrollmentId  String
  stepNumber    Int
  type          String   // email, task, wait
  status        String   @default("pending") // pending, sent, opened, clicked, failed
  scheduledAt   DateTime
  sentAt        DateTime?
  openedAt      DateTime?
  clickedAt     DateTime?
  errorMessage  String?
  
  enrollment    SequenceEnrollment @relation(fields: [enrollmentId], references: [id])

  @@index([orgId])
  @@index([enrollmentId])
  @@index([orgId, scheduledAt])
  @@map("sequence_activities")
}
