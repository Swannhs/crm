generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

model Employee {
  id        String  @id @default(uuid()) @db.Uuid
  orgId     String  @map("org_id") @db.Uuid
  userId    String  @map("user_id") // Links to auth system
  contactId String? @map("contact_id") @db.Uuid // Links to CRM contact

  jobTitle   String? @map("job_title")
  department String?
  salary     Int?    @default(0) // cents
  status     String  @default("active") // active, inactive, sabbatical

  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  availabilities  Availability[]
  timeOffRequests TimeOff[]
  schedules       Schedule[]
  workedRecords   WorkedEmployee[]

  @@map("employees")
}

model Availability {
  id         String   @id @default(uuid()) @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  orgId      String   @map("org_id") @db.Uuid

  dayOfWeek Int    @map("day_of_week") // 0-6
  startTime String @map("start_time") // HH:mm
  endTime   String @map("end_time") // HH:mm

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("availabilities")
}

model TimeOff {
  id         String   @id @default(uuid()) @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  orgId      String   @map("org_id") @db.Uuid

  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  type      String // vacation, sick, personal
  status    String   @default("pending") // pending, approved, rejected
  reason    String?  @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("time_off_requests")
}

model Schedule {
  id         String   @id @default(uuid()) @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  orgId      String   @map("org_id") @db.Uuid

  startTime DateTime @map("start_time")
  endTime   DateTime @map("end_time")
  position  String?
  notes     String?  @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("schedules")
}

model WorkedEmployee {
  id         String   @id @default(uuid()) @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  orgId      String   @map("org_id") @db.Uuid

  date        DateTime @db.Date
  hoursWorked Float    @map("hours_worked")
  earnings    Int      @default(0) // cents

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("worked_employees")
}

model Shift {
  id         String   @id @default(uuid()) @db.Uuid
  orgId      String   @map("org_id") @db.Uuid
  employeeId String?  @map("employee_id") @db.Uuid
  startTime  DateTime @map("start_time")
  endTime    DateTime @map("end_time")
  position   String?
  shiftName  String?  @map("shift_name")
  color      String?
  notes      String?  @db.Text
  isDraft    Boolean  @default(false) @map("is_draft")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([orgId])
  @@map("shifts")
}

model Salary {
  id            String   @id @default(uuid()) @db.Uuid
  orgId         String   @map("org_id") @db.Uuid
  employeeId    String   @map("employee_id") @db.Uuid
  amount        Float // hourly rate or monthly amount
  type          String   @default("hourly") // hourly | monthly | annual
  effectiveDate DateTime @default(now()) @map("effective_date")
  notes         String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([orgId, employeeId])
  @@map("salaries")
}

model Attendance {
  id         String    @id @default(uuid()) @db.Uuid
  orgId      String    @map("org_id") @db.Uuid
  employeeId String    @map("employee_id") @db.Uuid
  date       DateTime  @default(now())
  checkIn    DateTime? @map("check_in")
  checkOut   DateTime? @map("check_out")
  status     String    @default("present") // present | absent | late | half-day
  notes      String?   @db.Text
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([orgId, employeeId])
  @@map("attendance")
}

model Budget {
  id            String   @id @default(uuid()) @db.Uuid
  orgId         String   @map("org_id") @db.Uuid
  period        String // e.g. "2025-01", "2025-Q1"
  budgetedCents Int      @default(0) @map("budgeted_cents")
  actualCents   Int      @default(0) @map("actual_cents")
  notes         String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([orgId])
  @@map("budgets")
}

model EmployeeCategory {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  name        String
  description String?  @db.Text
  color       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([orgId])
  @@map("employee_categories")
}

model ActivityLog {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  employeeId  String?  @map("employee_id") @db.Uuid
  userId      String?  @map("user_id")
  action      String
  description String?  @db.Text
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([orgId, employeeId])
  @@map("activity_logs")
}

model Payroll {
  id               String   @id @default(uuid()) @db.Uuid
  orgId            String   @map("org_id") @db.Uuid
  createdBy        String   @map("created_by")
  periodStart      DateTime @map("period_start")
  periodEnd        DateTime @map("period_end")
  totalAmountCents Int      @default(0) @map("total_amount_cents")
  status           String   @default("draft") // draft | processing | completed | cancelled
  notes            String?  @db.Text
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  history PayrollHistory[]

  @@index([orgId])
  @@map("payrolls")
}

model PayrollHistory {
  id              String   @id @default(uuid()) @db.Uuid
  orgId           String   @map("org_id") @db.Uuid
  payrollId       String?  @map("payroll_id") @db.Uuid
  payroll         Payroll? @relation(fields: [payrollId], references: [id])
  employeeId      String   @map("employee_id") @db.Uuid
  grossCents      Int      @default(0) @map("gross_cents")
  netCents        Int      @default(0) @map("net_cents")
  deductionsCents Int      @default(0) @map("deductions_cents")
  paidAt          DateTime @default(now()) @map("paid_at")
  notes           String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([orgId, employeeId])
  @@map("payroll_history")
}
