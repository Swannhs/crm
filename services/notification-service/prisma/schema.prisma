generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

model Notification {
  id          String    @id @default(uuid()) @db.Uuid
  org_id      String    @db.Uuid
  user_id     String    @db.VarChar(80)
  type        String    // email | sms | push | call | system
  category    String?   // appointment | message | payment | marketing | community
  title       String?
  body        String?
  is_seen     Boolean   @default(false)
  is_read     Boolean   @default(false)
  is_archived Boolean   @default(false)
  seen_at     DateTime?
  archived_at DateTime?
  ref_id      String?   // external reference (e.g. message id)
  ref_type    String?   // type of reference
  metadata    Json      @default("{}")
  created_at  DateTime  @default(now())

  @@index([org_id])
  @@index([user_id])
  @@map("notifications")
}

model EmailMessage {
  id          String    @id @default(uuid()) @db.Uuid
  org_id      String    @db.Uuid
  created_by  String    @db.VarChar(80)
  subject     String?
  body        String?
  to          String[]
  cc          String[]  @default([])
  bcc         String[]  @default([])
  from_email  String?
  from_name   String?
  is_sent     Boolean   @default(false)
  sent_at     DateTime?
  is_deleted  Boolean   @default(false)
  metadata    Json      @default("{}")
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  @@index([org_id])
  @@map("email_messages")
}

model EmailCampaign {
  id          String    @id @default(uuid()) @db.Uuid
  org_id      String    @db.Uuid
  created_by  String    @db.VarChar(80)
  series_id   String    @unique @db.Uuid @default(uuid())
  name        String
  subject     String
  body        String
  status      String    @default("draft")  // draft | scheduled | sent | cancelled
  scheduled_at DateTime?
  sent_at     DateTime?
  is_deleted  Boolean   @default(false)
  metadata    Json      @default("{}")
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  @@index([org_id])
  @@map("email_campaigns")
}

model SmsMessage {
  id          String    @id @default(uuid()) @db.Uuid
  org_id      String    @db.Uuid
  created_by  String    @db.VarChar(80)
  to          String
  body        String
  status      String    @default("queued")  // queued | sent | delivered | failed
  twilio_sid  String?
  is_deleted  Boolean   @default(false)
  metadata    Json      @default("{}")
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  @@index([org_id])
  @@map("sms_messages")
}

model DeviceToken {
  id          String    @id @default(uuid()) @db.Uuid
  user_id     String    @db.VarChar(80)
  org_id      String?   @db.Uuid
  type        String    // expo | apns | voip
  token       String
  created_at  DateTime  @default(now())

  @@unique([user_id, token])
  @@map("device_tokens")
}

model NotificationSetting {
  id              String    @id @default(uuid()) @db.Uuid
  org_id          String    @db.Uuid @unique
  email_enabled   Boolean   @default(true)
  sms_enabled     Boolean   @default(true)
  push_enabled    Boolean   @default(true)
  settings        Json      @default("{}")
  updated_at      DateTime  @updatedAt

  @@map("notification_settings")
}

model ContactPhoneVerification {
  id               String    @id @default(uuid()) @db.Uuid
  orgId            String?   @map("org_id") @db.Uuid
  userRef          String?   @map("user_ref")
  phoneNumber      String    @map("phone_number")
  verificationCode String    @map("verification_code")
  source           String?
  status           String    @default("generated")
  expiresAt        DateTime  @map("expires_at")
  verifiedAt       DateTime? @map("verified_at")
  metadata         Json      @default("{}")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([phoneNumber])
  @@map("contact_phone_verifications")
}
