// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ContactMap {
  uuid      String   @id @default(uuid())
  odooId    Int      @unique
  status    String?  @default("new")
  createdAt DateTime @default(now())
}

model Pet {
  id        String    @id @default(uuid())
  contactId Int       // Odoo partner_id
  name      String
  breed     String?
  age       String?   // Keep for legacy/manual entry
  birthDate DateTime?
  photo     String?
  createdAt DateTime  @default(now())
}

model ContactFile {
  id        String   @id @default(uuid())
  contactId Int      // Odoo partner_id
  name      String
  size      String
  url       String
  type      String?
  createdAt DateTime @default(now())
}

model ContactTask {
  id        String   @id @default(uuid())
  contactId Int      // Odoo partner_id
  title     String
  dueDate   String?
  priority  String?  @default("Medium")
  status    String   @default("pending")
  createdAt DateTime @default(now())
}

model ContactActivity {
  id        String   @id @default(uuid())
  contactId Int      // Odoo partner_id
  type      String   // note, call, system, email
  title     String
  content   String?
  author    String   @default("System")
  color     String?  @default("info")
  icon      String?
  createdAt DateTime @default(now())
}

model ContactShift {
  id        String    @id @default(uuid())
  contactId Int       // Odoo partner_id
  clockIn   DateTime  @default(now())
  clockOut  DateTime?
  status    String    @default("Approved") // Pending, Approved, Rejected
  createdAt DateTime  @default(now())
}

model MarketingSuppressionEntry {
  id        String   @id @default(uuid())
  orgId     String
  channel   String   // email | sms
  value     String
  reason    String   // unsubscribed | bounce | complaint | manual | other
  source    String?
  createdAt DateTime @default(now())

  @@index([orgId, channel, value])
}

model MarketingContactConsent {
  id            String   @id @default(uuid())
  orgId         String
  contactId     String
  emailOptIn    Boolean?
  smsOptIn      Boolean?
  unsubscribed  Boolean  @default(false)
  updatedByUser String?
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  @@unique([orgId, contactId])
  @@index([orgId, unsubscribed])
}

model MarketingCampaignTemplateUsage {
  id                   String   @id @default(uuid())
  orgId                String
  campaignId           String
  templateId           String
  templateVersionId    String?
  templateNameSnapshot String
  subjectSnapshot      String?
  previewTextSnapshot  String?
  contentSnapshot      String?
  appliedByUserId      String?
  appliedAt            DateTime @default(now())
  createdAt            DateTime @default(now())

  @@index([orgId, campaignId, appliedAt])
  @@index([orgId, templateId, appliedAt])
}

model MarketingDeliveryEvent {
  id                String   @id @default(uuid())
  orgId             String
  campaignId        String
  recipientId       String?
  recipientEmail    String?
  recipientPhone    String?
  provider          String?
  providerEventId   String?
  providerMessageId String?
  eventType         String
  url               String?
  reason            String?
  rawPayload        Json?
  occurredAt        DateTime
  createdAt         DateTime @default(now())

  @@index([orgId, campaignId, occurredAt])
  @@index([orgId, provider, providerEventId])
  @@index([orgId, provider, providerMessageId])
}

model ScoringRule {
  id        String   @id @default(uuid())
  orgId     String
  scope     String   @default("both") // contact | lead | both
  category  String
  name      String
  weight    Int      @default(10)
  condition Json?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, active])
}

model ContactScore {
  id               String   @id @default(uuid())
  orgId            String
  contactOdooId    Int
  score            Int
  breakdown        Json?
  lastCalculatedAt DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([orgId, contactOdooId])
  @@index([orgId, score])
}

model LeadScore {
  id               String   @id @default(uuid())
  orgId            String
  leadOdooId       Int
  score            Int
  breakdown        Json?
  lastCalculatedAt DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([orgId, leadOdooId])
  @@index([orgId, score])
}

model SupportTicket {
  id                String   @id @default(uuid())
  orgId             String
  subject           String
  description       String?
  status            String   @default("open") // open | in_progress | waiting_customer | resolved | closed
  priority          String   @default("medium") // low | medium | high | urgent
  assigneeUserId    String?
  customerContactId Int?
  customerCompanyId Int?
  slaDueAt          DateTime?
  slaBreached       Boolean  @default(false)
  createdByUserId   String?
  closedAt          DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  notes   SupportTicketNote[]
  replies SupportTicketReply[]

  @@index([orgId, status, priority])
  @@index([orgId, assigneeUserId])
  @@index([orgId, customerContactId])
}

model SupportTicketNote {
  id         String   @id @default(uuid())
  orgId      String
  ticketId   String
  body       String
  authorId   String?
  createdAt  DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([orgId, ticketId])
}

model SupportTicketReply {
  id         String   @id @default(uuid())
  orgId      String
  ticketId   String
  body       String
  authorId   String?
  visibleToCustomer Boolean @default(true)
  createdAt  DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([orgId, ticketId])
}

model SupportKnowledgeCategory {
  id          String   @id @default(uuid())
  orgId       String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  articles SupportKnowledgeArticle[]

  @@index([orgId, name])
}

model SupportKnowledgeArticle {
  id          String   @id @default(uuid())
  orgId       String
  categoryId  String?
  title       String
  body        String
  isPublic    Boolean  @default(false)
  publishedAt DateTime?
  createdByUserId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category SupportKnowledgeCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([orgId, isPublic, publishedAt])
  @@index([orgId, categoryId])
}
