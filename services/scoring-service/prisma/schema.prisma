generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ScoringModel {
  id         String        @id @default(uuid())
  orgId      String
  name       String
  description String?
  thresholds Json
  isActive   Boolean       @default(true)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  rules      ScoringRule[]
  leadScores LeadScore[]

  @@index([orgId])
  @@index([orgId, isActive])
  @@map("scoring_models")
}

model ScoringRule {
  id         String       @id @default(uuid())
  orgId      String
  modelId    String
  name       String
  entityType String       @default("contact")
  conditions Json
  points     Int
  isActive   Boolean      @default(true)
  priority   Int          @default(0)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  model      ScoringModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([modelId, isActive, priority])
  @@map("scoring_rules")
}

model LeadScore {
  id            String       @id @default(uuid())
  orgId         String
  contactId     String
  modelId       String
  score         Int
  grade         String
  factors       Json
  previousScore Int?
  changedAt     DateTime     @default(now())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  model         ScoringModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, score])
  @@index([orgId, grade])
  @@unique([orgId, contactId, modelId])
  @@map("lead_scores")
}
