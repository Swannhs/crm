generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

model Post {
  id        String  @id @default(uuid()) @db.Uuid
  orgId     String  @map("org_id") @db.Uuid
  userId    String  @map("user_id")
  contactId String? @map("contact_id") @db.Uuid
  groupId   String? @map("group_id") @db.Uuid

  text        String? @db.Text
  postColor   String? @map("post_color")
  attachments Json    @default("[]")

  likesCount Int     @default(0) @map("likes_count")
  isDeleted  Boolean @default(false) @map("is_deleted")

  metadata  Json      @default("{}")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  comments  Comment[]

  @@map("posts")
}

model Comment {
  id        String  @id @default(uuid()) @db.Uuid
  postId    String  @map("post_id") @db.Uuid
  post      Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  orgId     String  @map("org_id") @db.Uuid
  userId    String  @map("user_id")
  contactId String? @map("contact_id") @db.Uuid

  text      String  @db.Text
  isDeleted Boolean @default(false) @map("is_deleted")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([postId])
  @@map("comments")
}

model Group {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  createdBy   String   @map("created_by")
  name        String
  description String?  @db.Text
  coverImage  String?  @map("cover_image")
  privacy     String   @default("public") // public | private
  isDeleted   Boolean  @default(false) @map("is_deleted")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members GroupMember[]

  @@index([orgId])
  @@map("groups")
}

model GroupMember {
  id       String   @id @default(uuid()) @db.Uuid
  groupId  String   @map("group_id") @db.Uuid
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId   String   @map("user_id")
  role     String   @default("member") // admin | moderator | member
  joinedAt DateTime @default(now()) @map("joined_at")

  @@unique([groupId, userId])
  @@index([groupId])
  @@map("group_members")
}

model Badge {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  name        String
  description String?
  icon        String?
  points      Int      @default(0)
  isPublic    Boolean  @default(true) @map("is_public")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  awardedTo UserBadge[]

  @@index([orgId])
  @@map("badges")
}

model UserBadge {
  id        String   @id @default(uuid()) @db.Uuid
  badgeId   String   @map("badge_id") @db.Uuid
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  orgId     String   @map("org_id") @db.Uuid
  userId    String   @map("user_id")
  awardedBy String   @map("awarded_by")
  awardedAt DateTime @default(now()) @map("awarded_at")

  @@index([orgId, userId])
  @@map("user_badges")
}

model Follow {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([orgId, followerId, followingId], name: "orgId_followerId_followingId")
  @@index([orgId, followerId])
  @@map("follows")
}

model CommunityActivity {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  userId      String   @map("user_id")
  action      String
  entityType  String?  @map("entity_type")
  entityId    String?  @map("entity_id")
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([orgId, userId])
  @@map("community_activities")
}

model PointRecord {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  userId    String   @map("user_id")
  points    Int
  reason    String?  @db.Text
  awardedBy String?  @map("awarded_by")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([orgId, userId])
  @@map("point_records")
}

model CommunitySettings {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @unique @map("org_id") @db.Uuid
  name        String?
  description String?  @db.Text
  coverImage  String?  @map("cover_image")
  features    Json     @default("{}")
  theme       Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("community_settings")
}

model CommunityProfile {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  userId      String   @map("user_id")
  displayName String?  @map("display_name")
  bio         String?  @db.Text
  avatar      String?
  links       Json     @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([orgId, userId], name: "orgId_userId")
  @@map("community_profiles")
}

model CommunityEvent {
  id          String    @id @default(uuid()) @db.Uuid
  orgId       String    @map("org_id") @db.Uuid
  createdBy   String    @map("created_by")
  title       String
  description String?   @db.Text
  startDate   DateTime  @map("start_date")
  endDate     DateTime? @map("end_date")
  location    String?
  coverImage  String?   @map("cover_image")
  isDeleted   Boolean   @default(false) @map("is_deleted")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([orgId])
  @@map("community_events")
}

model CommunityMember {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  email     String?
  contactId String?  @map("contact_id") @db.Uuid
  userId    String?  @map("user_id")
  invitedBy String?  @map("invited_by")
  role      String   @default("member")
  status    String   @default("invited") // invited | active | rejected | removed
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([orgId])
  @@map("community_members")
}
