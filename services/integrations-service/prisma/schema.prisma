generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model IntegrationConnection {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  organizationId String?  @db.Uuid
  provider        String
  accessToken     String?
  refreshToken    String?
  expiresAt       DateTime?
  tokenType       String?
  scope           String?
  accountId       String?
  accountName     String?
  isActive        Boolean  @default(true)
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, provider])
  @@index([organizationId])
  @@index([provider])
}

model GoogleIntegration {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  organizationId String?  @db.Uuid
  accessToken     String?
  refreshToken    String?
  expiresAt       DateTime?
  isConnected     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([organizationId])
}

model ZoomIntegration {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  organizationId String?  @db.Uuid
  accountId       String?
  accessToken     String?
  refreshToken    String?
  expiresAt       DateTime?
  webhookSecret   String?
  isConnected     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([organizationId])
}

model ZoomMeeting {
  id              String   @id @default(uuid()) @db.Uuid
  zoomId          String   @unique
  userId          String   @db.Uuid
  organizationId String?  @db.Uuid
  topic           String
  startTime       DateTime
  duration        Int?
  joinUrl         String?
  password        String?
  status          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([organizationId])
}

model ShopifyStore {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  organizationId String?  @db.Uuid
  shopDomain      String   @unique
  accessToken     String?
  scope           String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([organizationId])
}

model UberEatsConfig {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  organizationId String?  @db.Uuid
  storeId         String?
  accessToken     String?
  refreshToken    String?
  isActive        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([organizationId])
}

model EasyPostConfig {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  organizationId String?  @db.Uuid
  apiKey          String?
  isActive        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([organizationId])
}

model IntegrationActivity {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  organizationId String?  @db.Uuid
  provider        String
  action          String
  status          String   @default("success")
  details         Json?
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([provider])
  @@index([organizationId])
  @@map("integration_activities")
}

model UserIntegrationSettings {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid @unique
  timezone        String?
  apiKey          String?  @unique @map("api_key")
  fcmData         Json?    @map("fcm_data")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("user_integration_settings")
}

model MetaIntegration {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @db.Uuid @unique
  organizationId        String?  @db.Uuid
  wabaId                String?  @map("waba_id")
  accessToken           String?  @map("access_token")
  businessPhoneNumberId String?  @map("business_phone_number_id")
  appId                 String?  @map("app_id")
  loginType             String?  @map("login_type") // manual | embed
  embedData             Json?    @map("embed_data")
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([organizationId])
  @@map("meta_integrations")
}

model VoiceIntegration {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid @unique
  organizationId String?  @db.Uuid
  provider       String   @default("elevenlabs")
  apiKey         String?  @map("api_key")
  voiceId        String?  @map("voice_id")
  settings       Json?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([organizationId])
  @@map("voice_integrations")
}

model WhatsAppInstance {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  organizationId String?  @db.Uuid
  name            String?
  instanceId      String   @unique @map("instance_id")
  status          String   @default("disconnected") // connected | disconnected | initial
  qr              String?  @db.Text
  phone           String?
  metadata        Json?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([organizationId])
  @@map("whatsapp_instances")
}

model TelegramSession {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  organizationId String?  @db.Uuid
  name            String?
  sessionId       String   @unique @map("session_id")
  status          String   @default("disconnected")
  phone           String?
  metadata        Json?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([organizationId])
  @@map("telegram_sessions")
}

model ImageAsset {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid
  name           String
  url            String
  thumbnail      String?
  mimeType       String?  @map("mime_type")
  size           Int?
  category       String?
  tags           Json?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([organizationId, category])
  @@index([userId, createdAt])
  @@map("image_assets")
}
