// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated-rbac/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

model Organization {
  id          String                   @id @default(uuid()) @db.Uuid
  name        String
  slug        String?                  @unique
  metadata    Json                     @default("{}")
  createdAt   DateTime                 @default(now()) @map("created_at")
  updatedAt   DateTime                 @updatedAt @map("updated_at")
  locations   Location[]
  memberships OrganizationMembership[]

  @@map("organizations")
}

model OrganizationMembership {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String       @map("user_id") @db.VarChar(80)
  role           String       @default("org_staff")
  permissions    Json         @default("[]")
  metadata       Json         @default("{}")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId, role])
  @@map("organization_memberships")
}

model Location {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name    String
  email   String?
  phone   String?
  street  String?
  city    String?
  state   String?
  zipCode String? @map("zip_code")
  country String?

  unitType     String? @map("unit_type")
  status       String?
  isCompliance Boolean @default(false) @map("is_compliance")

  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@map("locations")
}

model OnboardingStatus {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.VarChar(80)
  tourStepId    String   @map("tour_step_id")
  tourCompleted Boolean  @default(false) @map("tour_completed")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([userId, tourStepId])
  @@index([userId])
  @@map("onboarding_statuses")
}
