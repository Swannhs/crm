generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

model Calendar {
  id         String   @id @default(uuid()) @db.Uuid
  orgId      String   @map("org_id") @db.Uuid
  userId     String   @map("user_id")
  name       String
  color      String   @default("#6366f1")
  isDefault  Boolean  @default(false) @map("is_default")
  isVisible  Boolean  @default(true) @map("is_visible")
  provider   String? // google | outlook | apple | internal
  externalId String?  @map("external_id")
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  events Event[]

  @@index([orgId, userId])
  @@map("calendars")
}

model CalendarSettings {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @unique @map("org_id") @db.Uuid
  timezone    String   @default("UTC")
  weekStart   Int      @default(0) @map("week_start") // 0=Sun, 1=Mon
  timeFormat  String   @default("12h") @map("time_format") // 12h | 24h
  defaultView String   @default("month") @map("default_view") // day | week | month | agenda
  theme       Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("calendar_settings")
}

model EventCategory {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  name      String
  color     String   @default("#6366f1")
  icon      String?
  createdAt DateTime @default(now()) @map("created_at")

  events Event[]

  @@index([orgId])
  @@map("event_categories")
}

model Event {
  id          String         @id @default(uuid()) @db.Uuid
  orgId       String         @map("org_id") @db.Uuid
  calendarId  String?        @map("calendar_id") @db.Uuid
  calendar    Calendar?      @relation(fields: [calendarId], references: [id])
  categoryId  String?        @map("category_id") @db.Uuid
  category    EventCategory? @relation(fields: [categoryId], references: [id])
  createdBy   String         @map("created_by")
  title       String
  description String?        @db.Text
  location    String?
  startDate   DateTime       @map("start_date")
  endDate     DateTime       @map("end_date")
  allDay      Boolean        @default(false) @map("all_day")
  isRecurring Boolean        @default(false) @map("is_recurring")
  recurrence  Json           @default("{}") @map("recurrence") // rrule config
  color       String?
  status      String         @default("confirmed") // confirmed | tentative | cancelled
  attendees   Json           @default("[]")
  metadata    Json           @default("{}")
  isDeleted   Boolean        @default(false) @map("is_deleted")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  scheduleItems EventScheduleItem[]
  activities    EventActivity[]

  @@index([orgId])
  @@map("events")
}

model EventScheduleItem {
  id          String   @id @default(uuid()) @db.Uuid
  eventId     String   @map("event_id") @db.Uuid
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orgId       String   @map("org_id") @db.Uuid
  title       String
  startTime   DateTime @map("start_time")
  endTime     DateTime @map("end_time")
  speaker     String?
  location    String?
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([eventId])
  @@map("event_schedule_items")
}

model EventActivity {
  id          String   @id @default(uuid()) @db.Uuid
  eventId     String   @map("event_id") @db.Uuid
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orgId       String   @map("org_id") @db.Uuid
  userId      String   @map("user_id")
  action      String
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([eventId])
  @@map("event_activities")
}
