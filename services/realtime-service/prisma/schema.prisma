generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model LiveChatChannel {
  id              String   @id @default(uuid()) @db.Uuid
  adminId         String   @db.Uuid
  organizationId  String?  @db.Uuid
  contactId       String?  @db.Uuid
  name            String?
  type            String   @default("direct")
  isActive        Boolean  @default(true)
  lastMessageAt   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([adminId])
  @@index([organizationId])
  @@index([contactId])
}

model LiveChatMessage {
  id              String   @id @default(uuid()) @db.Uuid
  channelId       String   @db.Uuid
  senderId       String   @db.Uuid
  senderType     String   @default("user")
  content         String
  messageType    String   @default("text")
  metadata        Json?
  isRead          Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([channelId])
  @@index([senderId])
}

model LiveChatContact {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  organizationId  String?  @db.Uuid
  name            String?
  email           String?
  phone           String?
  avatar          String?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([organizationId])
}

model LiveChatWidgetSetting {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  organizationId  String?  @db.Uuid
  widgetName      String?
  primaryColor   String   @default("#007bff")
  headerTitle     String   @default("Chat with us")
  greetingMessage String?
  offlineMessage  String?
  position        String   @default("right")
  showPowerBy     Boolean  @default(true)
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([organizationId])
}

model LiveChatStatistics {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId String?  @db.Uuid
  totalChats     Int      @default(0)
  activeChats     Int      @default(0)
  resolvedChats   Int      @default(0)
  missedChats     Int      @default(0)
  avgResponseTime Int     @default(0)
  date            DateTime @db.Date
  createdAt       DateTime @default(now())

  @@index([organizationId])
  @@index([date])
}

model SocketConnection {
  id              String   @id @default(uuid()) @db.Uuid
  socketId        String   @unique
  userId          String?  @db.Uuid
  organizationId  String?  @db.Uuid
  contactId       String?  @db.Uuid
  deviceType      String?
  metadata        Json?
  connectedAt     DateTime @default(now())
  disconnectedAt DateTime?

  @@index([organizationId])
  @@map("socket_connections")
}

model OmniConversation {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @db.Uuid
  contactId       String   @db.Uuid
  provider        String   // whatsapp | telegram | livechat | messenger
  providerRef     String?  // phone number or chat id
  status          String   @default("open") // open | closed | snoozed
  subject         String?
  lastMessage     String?  @db.Text
  lastMessageAt   DateTime?
  metadata        Json?
  assignedAgentId String?  @db.Uuid
  
  messages        OmniMessage[]
  participants    OmniParticipant[]

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([contactId])
  @@index([assignedAgentId])
  @@map("omni_conversations")
}

model OmniMessage {
  id              String   @id @default(uuid()) @db.Uuid
  conversationId  String   @db.Uuid
  senderId        String   // Can be contactId or userId
  senderType      String   // contact | agent | system
  content         String?  @db.Text
  type            String   @default("text") // text | image | audio | video | file | location
  status          String   @default("sent") // sent | delivered | read | failed
  direction       String   @default("inbound") // inbound | outbound
  metadata        Json?
  
  conversation    OmniConversation @relation(fields: [conversationId], references: [id])

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([conversationId])
  @@index([senderId])
  @@map("omni_messages")
}

model OmniParticipant {
  id              String   @id @default(uuid()) @db.Uuid
  conversationId  String   @db.Uuid
  participantId   String   @db.Uuid // userId or contactId
  participantType String   // agent | contact
  role            String   @default("member")

  conversation    OmniConversation @relation(fields: [conversationId], references: [id])

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([conversationId])
  @@index([participantId])
  @@map("omni_participants")
}

model OmniAgent {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @db.Uuid
  userId          String   @db.Uuid
  displayName     String?
  email           String?
  status          String   @default("available")
  isActive        Boolean  @default(true)
  metadata        Json?

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("omni_agents")
}

model OmniAgentTask {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @db.Uuid
  agentId         String   @db.Uuid
  conversationId  String?  @db.Uuid
  title           String
  description     String?
  status          String   @default("pending")
  priority        String   @default("normal")
  dueAt           DateTime?
  metadata        Json?

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([agentId])
  @@index([conversationId])
  @@map("omni_agent_tasks")
}
