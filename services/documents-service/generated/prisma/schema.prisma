generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

model Document {
  id                 String              @id @default(uuid()) @db.Uuid
  org_id             String              @db.Uuid
  created_by_user_id String              @db.VarChar(80)
  name               String
  cloud_url          String
  type               String // general | contract | task | income | expense
  status             String              @default("draft")
  is_deleted         Boolean             @default(false)
  metadata           Json                @default("{}")
  created_at         DateTime            @default(now())
  updated_at         DateTime            @updatedAt
  recipients         DocumentRecipient[]
  activities         DocumentActivity[]

  @@index([org_id])
  @@map("documents")
}

model DocumentRecipient {
  id             String             @id @default(uuid()) @db.Uuid
  document_id    String             @db.Uuid
  document       Document           @relation(fields: [document_id], references: [id], onDelete: Cascade)
  org_id         String             @db.Uuid
  contact_id     String?            @db.Uuid
  name           String
  email          String
  status         String             @default("pending") // pending | signed | declined | viewed
  hash_code      String?            @unique
  signed_at      DateTime?
  is_deleted     Boolean            @default(false)
  otp            String?
  otp_expires_at DateTime?
  metadata       Json               @default("{}")
  created_at     DateTime           @default(now())
  updated_at     DateTime           @updatedAt
  activities     DocumentActivity[]

  @@index([org_id])
  @@index([hash_code])
  @@map("document_recipients")
}

model DocumentActivity {
  id                    String             @id @default(uuid()) @db.Uuid
  document_id           String             @db.Uuid
  document              Document           @relation(fields: [document_id], references: [id], onDelete: Cascade)
  document_recipient_id String?            @db.Uuid
  recipient             DocumentRecipient? @relation(fields: [document_recipient_id], references: [id])
  org_id                String             @db.Uuid
  action                String
  ip_address            String?
  user_agent            String?
  metadata              Json               @default("{}")
  created_at            DateTime           @default(now())

  @@index([document_id])
  @@index([document_recipient_id])
  @@map("document_activities")
}
