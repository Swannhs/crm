generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

model Income {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  organizationId String?  @db.Uuid
  amount          Decimal  @db.Decimal(10, 2)
  category        String?
  description     String?
  date            DateTime @db.Date
  source          String?
  eventId         String?  @db.Uuid
  contactId       String?  @db.Uuid
  isRecurring     Boolean  @default(false)
  recurringType  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([organizationId])
  @@index([date])
}

model Expense {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  organizationId String?  @db.Uuid
  amount          Decimal  @db.Decimal(10, 2)
  category        String?
  description     String?
  date            DateTime @db.Date
  vendor          String?
  contactId       String?  @db.Uuid
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([organizationId])
  @@index([date])
}

model Deposit {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  organizationId String?  @db.Uuid
  amount          Decimal  @db.Decimal(10, 2)
  paymentMethod  String?
  status          String   @default("pending")
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([organizationId])
}

model PaymentPaypal {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  organizationId String?  @db.Uuid
  payoutBatchId   String?
  amount          Decimal  @db.Decimal(10, 2)
  currency        String   @default("USD")
  status          String   @default("pending")
  recipientEmail  String?
  transactionId   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([organizationId])
}

model PaymentValor {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  organizationId String?  @db.Uuid
  amount          Decimal  @db.Decimal(10, 2)
  currency        String   @default("USD")
  status          String   @default("pending")
  transactionId  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([organizationId])
}

model FinanceCategory {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  organizationId String?  @db.Uuid
  name            String
  type            String
  color           String?
  icon            String?
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([organizationId])
}

model TaxSales {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  organizationId String?  @db.Uuid
  name            String
  rate            Decimal  @db.Decimal(5, 2)
  region          String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([organizationId])
}

model FinanceStatement {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId String?  @db.Uuid
  type            String
  startDate       DateTime
  endDate         DateTime
  totalIncome    Decimal  @db.Decimal(12, 2) @default(0)
  totalExpense   Decimal  @db.Decimal(12, 2) @default(0)
  netProfit      Decimal  @db.Decimal(12, 2) @default(0)
  data            Json?
  createdAt       DateTime @default(now())

  @@index([organizationId])
}

model SuperAdminFinance {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId String?  @db.Uuid
  revenue        Decimal  @db.Decimal(12, 2) @default(0)
  expenses       Decimal  @db.Decimal(12, 2) @default(0)
  profit         Decimal  @db.Decimal(12, 2) @default(0)
  period         String
  createdAt       DateTime @default(now())

  @@index([organizationId])
}
