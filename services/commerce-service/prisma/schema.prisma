generator client {
  provider = "prisma-client-js"
  output   = "../generated-local/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

model Product {
  id           String      @id @default(uuid()) @db.Uuid
  orgId        String      @map("org_id") @db.Uuid
  name         String
  description  String?     @db.Text
  priceCents   Int         @map("price_cents")
  currency     String      @default("USD")
  status       String      @default("draft")
  photos       Json        @default("[]")
  metadata     Json        @default("{}")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  
  // Relations
  orderItems     OrderItem[]
  variants       ProductVariant[]
  modifierGroups ProductModifierGroup[]
  attributes     ProductAttribute[]

  @@map("products")
}

model ProductVariant {
  id           String   @id @default(uuid()) @db.Uuid
  productId    String   @map("product_id") @db.Uuid
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name         String
  sku          String?
  priceCents   Int      @map("price_cents")
  stock        Int      @default(0)
  options      Json     @default("{}") // e.g. {"color": "red", "size": "XL"}
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("product_variants")
}

model ProductAttribute {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String   // e.g. "Color", "Size"
  values    String[] // e.g. ["Red", "Blue"]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("product_attributes")
}

model ProductModifierGroup {
  id          String            @id @default(uuid()) @db.Uuid
  productId   String            @map("product_id") @db.Uuid
  product     Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  name        String            // e.g. "Add-ons", "Pizza Toppings"
  minSelected Int               @default(0) @map("min_selected")
  maxSelected Int?              @map("max_selected")
  modifiers   ProductModifier[]
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@map("product_modifier_groups")
}

model ProductModifier {
  id              String               @id @default(uuid()) @db.Uuid
  modifierGroupId String               @map("modifier_group_id") @db.Uuid
  group           ProductModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)
  name            String
  priceCents      Int                  @default(0) @map("price_cents")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  @@map("product_modifiers")
}

model Customer {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  contactId    String   @unique @map("contact_id") @db.Uuid // Links to CRM Contact
  email        String
  passwordHash String   @map("password_hash")
  points       Int      @default(0)
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  orders       Order[]
  carts        Cart[]

  @@unique([orgId, email])
  @@index([orgId])
  @@map("customers")
}

model Order {
  id                String      @id @default(uuid()) @db.Uuid
  orgId             String      @map("org_id") @db.Uuid
  customerId        String?     @map("customer_id") @db.Uuid
  customer          Customer?   @relation(fields: [customerId], references: [id])
  contactId         String?     @map("contact_id") @db.Uuid
  userId            String?     @map("user_id")
  totalAmountCents  Int         @map("total_amount_cents")
  status            String      @default("pending")
  paymentStatus     String      @default("unpaid") @map("payment_status")
  shippingAddress   Json?       @map("shipping_address")
  metadata          Json        @default("{}")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  items             OrderItem[]

  @@map("orders")
}

model OrderItem {
  id             String   @id @default(uuid()) @db.Uuid
  orderId        String   @map("order_id") @db.Uuid
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      String   @map("product_id") @db.Uuid
  product        Product  @relation(fields: [productId], references: [id])
  productName    String   @map("product_name")
  quantity       Int
  unitPriceCents Int      @map("unit_price_cents")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([orderId])
  @@map("order_items")
}

model Category {
  id          String    @id @default(uuid()) @db.Uuid
  orgId       String    @map("org_id") @db.Uuid
  name        String
  description String?
  parentId    String?   @map("parent_id") @db.Uuid
  slug        String?
  image_url   String?
  isActive    Boolean   @default(true) @map("is_active")
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([orgId])
  @@map("categories")
}

model Coupon {
  id              String    @id @default(uuid()) @db.Uuid
  orgId           String    @map("org_id") @db.Uuid
  code            String
  type            String    // percent | fixed
  value           Int       // percent 0-100 or fixed cents
  minOrderCents   Int       @default(0) @map("min_order_cents")
  maxUsage        Int?      @map("max_usage")
  usedCount       Int       @default(0) @map("used_count")
  expiresAt       DateTime? @map("expires_at")
  isActive        Boolean   @default(true) @map("is_active")
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@unique([orgId, code])
  @@index([orgId])
  @@map("coupons")
}

model Cart {
  id          String     @id @default(uuid()) @db.Uuid
  orgId       String     @map("org_id") @db.Uuid
  customerId  String?    @map("customer_id") @db.Uuid
  customer    Customer?  @relation(fields: [customerId], references: [id])
  userId      String?    @map("user_id")
  contactId   String?    @map("contact_id") @db.Uuid
  sessionId   String?    @map("session_id")
  status      String     @default("active") // active | converted | abandoned
  metadata    Json       @default("{}")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  items       CartItem[]

  @@index([orgId])
  @@map("carts")
}

model CartItem {
  id             String   @id @default(uuid()) @db.Uuid
  cartId         String   @map("cart_id") @db.Uuid
  cart           Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId      String   @map("product_id") @db.Uuid
  productName    String   @map("product_name")
  unitPriceCents Int      @map("unit_price_cents")
  quantity       Int
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([cartId])
  @@map("cart_items")
}
