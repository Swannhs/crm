generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

model PosSetting {
  id                          String      @id @default(uuid()) @db.Uuid
  shopId                      String?     @db.Uuid
  organizationId              String?     @db.Uuid
  numberPadFirstValue         Int?
  numberPadSecondValue        Int?
  numberPadThirdValue         Int?
  configureTipFirstPercentage Int?        @default(0)
  configureTipSecondPercentage Int?       @default(0)
  configureTipThirdPercentage Int?        @default(0)
  configureTipFourthPercentage Int?       @default(0)
  cfd                         Boolean     @default(false)
  cfdSettings                 Json?
  tipShifts                   Json?
  createdAt                   DateTime    @default(now())
  updatedAt                   DateTime    @updatedAt

  @@index([shopId])
  @@index([organizationId])
}

model PosTable {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String?   @db.Uuid
  organizationId  String?   @db.Uuid
  shopId          String?   @db.Uuid
  roomId          String?   @db.Uuid
  serverId        String?   @db.Uuid
  tableName       String
  tableShape      String
  tableLink       String?
  tableColor      String    @default("#a6b5e1")
  tableDimension  Json?
  seats           Json?
  isDeleted       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([shopId])
  @@index([organizationId])
}

model PosTableMode {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String?   @db.Uuid
  shopId          String?   @db.Uuid
  organizationId  String?   @db.Uuid
  tableNo         String?
  guestCount      Int?
  orderState      String?
  serverId        String?   @db.Uuid
  seats           Json?
  sendTime        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([shopId])
  @@index([organizationId])
}

model PosTableOrder {
  id              String    @id @default(uuid()) @db.Uuid
  tableId         String    @db.Uuid
  userId          String?   @db.Uuid
  organizationId  String?   @db.Uuid
  shopId          String?   @db.Uuid
  roomId          String?   @db.Uuid
  tableName       String
  seats           Json?
  orderStatus     String?
  isDelete        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tableId])
  @@index([shopId])
  @@index([organizationId])
}