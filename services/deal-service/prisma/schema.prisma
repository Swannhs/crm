generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Deal {
  id          String   @id @default(uuid())
  orgId       String   @index
  name        String
  description String?
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("USD")
  stage       String   @index // prospect, qualification, proposal, negotiation, closed_won, closed_lost
  probability Int      @default(0) // 0-100
  expectedCloseDate DateTime?
  actualCloseDate   DateTime?
  closeReason       String?
  ownerId     String   @index
  contactId   String?  @index
  companyId   String?  @index
  pipelineId  String?  @index
  source      String?  // website, referral, inbound, outbound, event
  priority    String   @default("medium") // low, medium, high, urgent
  tags        String[] 
  customFields Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  closedAt    DateTime?

  // Relations
  owner       User?    @relation(fields: [ownerId], references: [id])
  contact     Contact? @relation(fields: [contactId], references: [id])
  company     Company? @relation(fields: [companyId], references: [id])
  pipeline    Pipeline? @relation(fields: [pipelineId], references: [id])
  activities  Activity[]
  notes       Note[]
  tasks       Task[]

  @@index([orgId, stage])
  @@index([orgId, ownerId])
  @@index([expectedCloseDate])
  @@map("deals")
}

model Pipeline {
  id          String   @id @default(uuid())
  orgId       String   @index
  name        String
  description String?
  isActive    Boolean  @default(true)
  stages      Json     // Array of stage objects with order and color
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deals       Deal[]

  @@map("pipelines")
}

model Contact {
  id        String   @id @default(uuid())
  orgId     String   @index
  firstName String
  lastName  String
  email     String?  @index
  phone     String?
  title     String?
  companyId String?  @index
  
  deals     Deal[]
  
  @@map("contacts")
}

model Company {
  id        String   @id @default(uuid())
  orgId     String   @index
  name      String
  website   String?
  industry  String?
  size      String?
  
  deals     Deal[]
  
  @@map("companies")
}

model User {
  id        String   @id @default(uuid())
  orgId     String   @index
  email     String   @unique
  name      String?
  
  deals     Deal[]
  
  @@map("users")
}

model Activity {
  id        String   @id @default(uuid())
  orgId     String   @index
  type      String   // call, email, meeting, note, task
  subject   String?
  content   String?
  dealId    String?  @index
  contactId String?  @index
  ownerId   String   @index
  dueDate   DateTime?
  completed Boolean  @default(false)
  completedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deal      Deal?    @relation(fields: [dealId], references: [id])

  @@index([orgId, type])
  @@index([orgId, ownerId])
  @@map("activities")
}

model Note {
  id        String   @id @default(uuid())
  orgId     String   @index
  content   String
  dealId    String?  @index
  contactId String?  @index
  ownerId   String   @index
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deal      Deal?    @relation(fields: [dealId], references: [id])

  @@map("notes")
}

model Task {
  id          String   @id @default(uuid())
  orgId       String   @index
  title       String
  description String?
  dealId      String?  @index
  contactId   String?  @index
  ownerId     String   @index
  assignedTo  String?  @index
  dueDate     DateTime?
  priority    String   @default("medium")
  status      String   @default("pending") // pending, in_progress, completed, cancelled
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deal        Deal?    @relation(fields: [dealId], references: [id])

  @@index([orgId, status])
  @@index([orgId, ownerId])
  @@map("tasks")
}
