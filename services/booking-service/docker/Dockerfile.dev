FROM node:24-bookworm-slim

RUN apt-get update && apt-get install -y openssl libc6 \
  && rm -rf /var/lib/apt/lists/* \
  && corepack enable

ARG SERVICE_NAME
ENV SERVICE_NAME=${SERVICE_NAME}
WORKDIR /app

# Copy service manifest first for caching
COPY services/${SERVICE_NAME}/package.json ./services/${SERVICE_NAME}/package.json

# Install dependencies ONLY for this service
WORKDIR /app/services/${SERVICE_NAME}
RUN yarn install

# Copy rest of the service source
WORKDIR /app
COPY services/${SERVICE_NAME} ./services/${SERVICE_NAME}

WORKDIR /app/services/${SERVICE_NAME}
# Handle prisma if present
RUN if [ -f "prisma/schema.prisma" ]; then npx prisma generate; fi

COPY services/${SERVICE_NAME}/docker/entrypoint.standalone.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["yarn", "dev"]
