generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

model BookingType {
  id                 String @id @default(uuid()) @db.Uuid
  org_id             String @db.Uuid
  created_by_user_id String @db.VarChar(80)

  title        String
  description  String?
  link         String  @unique
  meeting_type String  @default("inperson")
  location     String?
  geo_location Json?   @default("{}")

  duration_minutes Int     @default(30)
  color            String? @default("#3b82f6")

  notification_mins Int?
  notification_type String? @default("email")
  email_subject     String?
  email_body        String?

  submit_button_label String @default("Schedule Meeting")

  status      String  @default("active")
  is_archived Boolean @default(false)

  synced_with_schedule Boolean @default(false)

  metadata   Json     @default("{}")
  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  slots        BookingSlot[]
  appointments Appointment[]

  @@index([org_id])
  @@index([link])
  @@map("booking_types")
}

model BookingSlot {
  id              String      @id @default(uuid()) @db.Uuid
  booking_type_id String      @db.Uuid
  booking_type    BookingType @relation(fields: [booking_type_id], references: [id], onDelete: Cascade)

  date         DateTime
  start_time   String
  end_time     String
  is_available Boolean  @default(true)
  capacity     Int      @default(1)
  booked_count Int      @default(0)

  metadata   Json     @default("{}")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([booking_type_id])
  @@index([date])
  @@map("booking_slots")
}

model Appointment {
  id                 String       @id @default(uuid()) @db.Uuid
  org_id             String       @db.Uuid
  booking_type_id    String?      @db.Uuid
  booking_type       BookingType? @relation(fields: [booking_type_id], references: [id], onDelete: SetNull)
  created_by_user_id String       @db.VarChar(80)

  title       String
  description String?
  note        String?

  contact_id    String?  @db.Uuid
  invited_users String[] @default([])

  meeting_type String  @default("inperson")
  meeting_link String?
  location     String?
  geo_location Json?   @default("{}")

  start_datetime   DateTime
  end_datetime     DateTime
  duration_minutes Int      @default(30)

  color String @default("primary")

  notification_mins Int?
  notification_type String?
  status            String  @default("scheduled")

  series_id    String?
  is_recurring Boolean @default(false)

  metadata   Json     @default("{}")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([org_id])
  @@index([contact_id])
  @@index([start_datetime])
  @@map("appointments")
}

model BookingTypeGroup {
  id                 String @id @default(uuid()) @db.Uuid
  org_id             String @db.Uuid
  created_by_user_id String @db.VarChar(80)

  name             String
  description      String?
  booking_type_ids String[] @default([])

  metadata   Json     @default("{}")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([org_id])
  @@map("booking_type_groups")
}
