{
  "version": 3,
  "name": "mymanager-krakend",
  "port": 8081,
  "timeout": "3000ms",
  "cache_ttl": "300s",
  "extra_config": {
    "auth/validator": {
      "shared_cache_duration": 900
    }
  },
  "endpoints": [
    {
      "endpoint": "/health",
      "backend": [
        {
          "host": ["http://organization-service:7010"],
          "url_pattern": "/healthz"
        }
      ]
    },
    {
      "endpoint": "/protected/hello",
      "input_headers": ["Authorization", "X-User-Id", "X-Org-Id"],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/mymanager/protocol/openid-connect/certs",
          "disable_jwk_security": true,
          "cache": true,
          "propagate_claims": [
            ["sub", "X-User-Id"],
            ["org_id", "X-Org-Id"]
          ]
        }
      },
      "backend": [
        {
          "host": ["http://organization-service:7010"],
          "url_pattern": "/v1/hello",
          "extra_config": {
            "auth/validator": {}
          }
        }
      ]
    },
    {
      "endpoint": "/crm/v1/contacts",
      "method": "GET",
      "input_headers": ["Authorization", "X-User-Id", "X-Org-Id"],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/mymanager/protocol/openid-connect/certs",
          "disable_jwk_security": true,
          "cache": true,
          "propagate_claims": [
            ["sub", "X-User-Id"],
            ["org_id", "X-Org-Id"]
          ]
        }
      },
      "backend": [
        {
          "host": ["http://crm-service:8010"],
          "url_pattern": "/api/v1/contacts",
          "extra_config": {
            "auth/validator": {}
          }
        }
      ]
    },
    {
      "endpoint": "/crm/v1/contacts",
      "method": "POST",
      "input_headers": ["Authorization", "Content-Type", "X-User-Id", "X-Org-Id"],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/mymanager/protocol/openid-connect/certs",
          "disable_jwk_security": true,
          "cache": true,
          "propagate_claims": [
            ["sub", "X-User-Id"],
            ["org_id", "X-Org-Id"]
          ]
        }
      },
      "backend": [
        {
          "host": ["http://crm-service:8010"],
          "url_pattern": "/api/v1/contacts",
          "extra_config": {
            "auth/validator": {}
          }
        }
      ]
    },
    {
      "endpoint": "/crm/v1/contacts/{contact}",
      "method": "GET",
      "input_headers": ["Authorization", "X-User-Id", "X-Org-Id"],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/mymanager/protocol/openid-connect/certs",
          "disable_jwk_security": true,
          "cache": true,
          "propagate_claims": [
            ["sub", "X-User-Id"],
            ["org_id", "X-Org-Id"]
          ]
        }
      },
      "backend": [
        {
          "host": ["http://crm-service:8010"],
          "url_pattern": "/api/v1/contacts/{contact}",
          "extra_config": {
            "auth/validator": {}
          }
        }
      ]
    },
    {
      "endpoint": "/org/v1/organizations",
      "method": "GET",
      "input_headers": ["Authorization", "X-User-Id", "X-Org-Id"],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/mymanager/protocol/openid-connect/certs",
          "disable_jwk_security": true,
          "cache": true,
          "propagate_claims": [
            ["sub", "X-User-Id"],
            ["org_id", "X-Org-Id"]
          ]
        }
      },
      "backend": [
        {
          "host": ["http://organization-service:7010"],
          "url_pattern": "/v1/organizations",
          "extra_config": {
            "auth/validator": {}
          }
        }
      ]
    },
    {
      "endpoint": "/billing/v1/invoices",
      "method": "POST",
      "input_headers": ["Authorization", "Content-Type", "X-User-Id", "X-Org-Id"],
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_url": "http://keycloak:8080/realms/mymanager/protocol/openid-connect/certs",
          "disable_jwk_security": true,
          "cache": true,
          "propagate_claims": [
            ["sub", "X-User-Id"],
            ["org_id", "X-Org-Id"]
          ]
        }
      },
      "backend": [
        {
          "host": ["http://billing-service:7020"],
          "url_pattern": "/v1/invoices",
          "extra_config": {
            "auth/validator": {}
          }
        }
      ]
    }
  ]
}
