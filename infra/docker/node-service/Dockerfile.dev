FROM node:24-alpine

ARG SERVICE_NAME
ARG SERVICE_PORT

ENV SERVICE_NAME=${SERVICE_NAME}
ENV PORT=${SERVICE_PORT}
ENV NODE_ENV=development

WORKDIR /workspace/services/${SERVICE_NAME}

RUN apk add --no-cache openssl libc6-compat \
  && corepack enable

EXPOSE ${SERVICE_PORT}

CMD ["sh", "-c", "set -e; cd /workspace; mkdir -p node_modules; INSTALL_STAMP=/workspace/node_modules/.install-complete; INSTALL_LOCK=/workspace/node_modules/.install-lock; if [ ! -f \"$INSTALL_STAMP\" ]; then if mkdir \"$INSTALL_LOCK\" 2>/dev/null; then trap 'rmdir \"$INSTALL_LOCK\" 2>/dev/null || true' EXIT; corepack yarn install --network-timeout 600000; date > \"$INSTALL_STAMP\"; rmdir \"$INSTALL_LOCK\" 2>/dev/null || true; trap - EXIT; else until [ -f \"$INSTALL_STAMP\" ]; do echo \"Waiting for shared workspace install to finish...\"; sleep 2; done; fi; fi; cd services/${SERVICE_NAME}; if [ -d prisma ]; then corepack yarn exec prisma generate; fi; exec corepack yarn dev"]
